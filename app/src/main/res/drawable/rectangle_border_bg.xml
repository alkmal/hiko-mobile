<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Outer Gradient Border Layer -->
    <item>
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#E72392"
                android:endColor="#9029FF"
                android:angle="315"
                android:type="linear" />
            <corners android:radius="20dp" />
        </shape>
    </item>

    <!-- Inner Solid Layer (with matching corner radius minus padding) -->
    <item android:left="1dp" android:right="1dp" android:top="1dp" android:bottom="1dp">
        <shape android:shape="rectangle">
            <!-- Use white or any contrasting color to show border -->
            <solid android:color="#2B0E47" />
            <corners android:radius="20dp" />
        </shape>
    </item>

</layer-list>
