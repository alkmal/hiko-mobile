<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/main_bg"
        android:orientation="vertical"
        android:fitsSystemWindows="true"
        tools:context=".musicfunction.AddMusicActivity">

        <RelativeLayout
            android:id="@+id/lytTop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp">

            <ImageView
                android:id="@+id/ivBack"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_centerVertical="true"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_music_back" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:layout_marginStart="20dp"
                android:layout_centerHorizontal="true"
                android:fontFamily="@font/airbnb_cereal_bold"
                android:text="@string/my_music"
                android:textColor="@color/white"
                android:textSize="20sp" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/ivDelete"
                    android:layout_width="37dp"
                    android:layout_height="37dp"
                    android:layout_marginEnd="15dp"
                    android:src="@drawable/ic_music_delete" />

                <ImageView
                    android:id="@+id/ivaddMusic"
                    android:layout_width="37dp"
                    android:layout_height="37dp"
                    android:layout_marginEnd="10dp"
                    android:src="@drawable/add_music" />

            </LinearLayout>
        </RelativeLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvMusic"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/txtplay"
            android:layout_below="@id/lytTop"
            android:layout_margin="10dp" />

        <TextView
            android:id="@+id/noMusic"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_35sdp"
            android:layout_centerInParent="true"
            android:layout_gravity="center"
            android:fontFamily="@font/airbnb_cereal_bold"
            android:gravity="center"
            android:text="No Music Found!"
            android:textColor="@color/white"
            android:textSize="@dimen/_14sdp"
            android:visibility="gone" />

        <TextView
            android:id="@+id/txtplay"
            android:layout_width="match_parent"
            android:layout_height="@dimen/_35sdp"
            android:layout_alignParentBottom="true"
            android:layout_gravity="center"
            android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="20dp"
            android:background="@drawable/gradient_bg_radius_50"
            android:fontFamily="@font/airbnb_cereal_bold"
            android:gravity="center"
            android:text="Play"
            android:textColor="@color/white"
            android:textSize="@dimen/_14sdp" />

    </RelativeLayout>
</layout>