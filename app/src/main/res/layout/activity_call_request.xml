<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/black_back"
        tools:context=".chat.activity.CallRequestActivity">

        <ImageView
            android:id="@+id/backBlurImage"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:alpha=".3"
            android:scaleType="centerCrop" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginVertical="70dp"
            android:gravity="center"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="130dp"
                android:layout_height="130dp"
                android:background="@drawable/bg_calluser">

                <com.github.ybq.android.spinkit.SpinKitView
                    android:id="@+id/spin_kit"
                    style="@style/SpinKitView.Large.DoubleBounce"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:alpha=".5"
                    app:SpinKit_Color="@color/tintColor" />

                <com.codder.ultimate.utils.UserProfileImageView
                    android:id="@+id/imgUser"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:layout_centerInParent="true" />
            </RelativeLayout>

            <TextView
                android:id="@+id/tvName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/airbnbcereal_w_md"
                android:text="@string/dummy_name"
                android:layout_marginTop="10dp"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerHorizontal="true"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:text="@string/ringing"
                    android:layout_centerVertical="true"
                    android:textColor="@color/white_60"
                    android:textSize="15sp" />

                <com.airbnb.lottie.LottieAnimationView
                    android:layout_width="@dimen/_24sdp"
                    android:layout_height="@dimen/_20sdp"
                    android:layout_toEndOf="@+id/tvStatus"
                    android:scaleType="centerCrop"
                    android:visibility="gone"
                    android:layout_marginTop="10dp"
                    app:lottie_colorFilter="@color/whiteColor"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_fileName="call_ringing_dot.json" />
            </RelativeLayout>

            <View
                android:layout_width="1dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/btnDecline"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:background="@drawable/btn_bg"
                    android:backgroundTint="@color/red"
                    android:padding="15dp"
                    android:rotation="135"
                    android:src="@drawable/call"
                    app:tint="@color/white" />
            </LinearLayout>
        </LinearLayout>

        <include layout="@layout/layout_no_internet" />
    </RelativeLayout>
</layout>