<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        android:orientation="vertical">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/edit_profile" />
            
            <ImageView
                android:layout_width="44sp"
                android:layout_height="44sp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15sp"
                android:visibility="gone"
                android:src="@drawable/ic_save"/>
        </RelativeLayout>


        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/_5sdp">

                    <RelativeLayout
                        android:layout_width="115dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:layout_marginTop="10sp"
                        android:layout_marginStart="10sp">

                        <com.codder.ultimate.utils.UserProfileImageView
                            android:id="@+id/imgUser"
                            android:layout_width="112sp"
                            android:layout_height="112sp"
                            android:src="@drawable/girl"
                            android:visibility="visible" />

                        <ImageView
                            android:id="@+id/btnPencil"
                            android:layout_width="30sp"
                            android:layout_height="30sp"
                            android:layout_alignParentEnd="true"
                            android:layout_alignParentBottom="true"
                            android:layout_marginEnd="7dp"
                            android:src="@drawable/edit_profile" />

                    </RelativeLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10sp"
                        android:layout_marginTop="20sp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="@string/enter_name"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/etName"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginHorizontal="10sp"
                        android:layout_marginTop="10sp"
                        android:background="@drawable/bg_12dp_stockwhite15"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:hint="@string/your_name"
                        android:imeOptions="actionNext"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="15sp"
                        android:singleLine="true"
                        android:textAlignment="viewStart"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white_50"
                        android:textSize="16sp" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10sp"
                        android:layout_marginTop="15sp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="Select Gender"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/genderLayout"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginHorizontal="10sp"
                        android:layout_marginTop="10sp"
                        android:gravity="center_horizontal"
                        android:orientation="horizontal">

                        <RelativeLayout
                            android:id="@+id/lytMale"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginEnd="7sp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:padding="@dimen/_10sdp">

                            <ImageView
                                android:id="@+id/imgmale"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"

                                android:layout_centerVertical="true"
                                android:src="@drawable/male_avatar" />

                            <TextView
                                android:id="@+id/tvMale"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="8dp"
                                android:layout_toEndOf="@id/imgmale"
                                android:fontFamily="@font/airbnbcereal_w_md"
                                android:text="@string/male"
                                android:textColor="@color/white"
                                android:textSize="16sp" />

                            <ImageView
                                android:id="@+id/rbMale"
                                android:layout_width="22sp"
                                android:layout_height="22sp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_check_selector"
                                android:visibility="visible" />
                        </RelativeLayout>

                        <RelativeLayout
                            android:id="@+id/lytFemale"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="7sp"
                            android:layout_weight="1"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:padding="@dimen/_10sdp">

                            <ImageView
                                android:id="@+id/imgfemale"
                                android:layout_width="@dimen/_24sdp"
                                android:layout_height="@dimen/_24sdp"
                                android:layout_alignParentStart="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/female_avatar" />

                            <TextView
                                android:id="@+id/tvFemale"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_centerVertical="true"
                                android:layout_marginStart="8dp"
                                android:layout_toEndOf="@id/imgfemale"
                                android:fontFamily="@font/airbnbcereal_w_md"
                                android:text="@string/female"
                                android:textColor="@color/white"
                                android:textSize="16sp" />

                            <ImageView
                                android:id="@+id/rbFemale"
                                android:layout_width="22sp"
                                android:layout_height="22sp"
                                android:layout_alignParentEnd="true"
                                android:layout_centerVertical="true"
                                android:src="@drawable/ic_check_selector"
                                android:visibility="visible" />
                        </RelativeLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="10sp"
                        android:layout_marginTop="15sp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="Enter Age"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/etAge"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginHorizontal="10sp"
                        android:layout_marginTop="10sp"
                        android:background="@drawable/bg_12dp_stockwhite15"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:hint="Your Age"
                        android:imeOptions="actionNext"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="15sp"
                        android:singleLine="true"
                        android:textAlignment="viewStart"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white_50"
                        android:textSize="16sp" />

                    <com.shawnlin.numberpicker.NumberPicker
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginTop="5dp"
                        app:np_dividerColor="@color/white"
                        app:np_dividerLength="@dimen/_30sdp"
                        app:np_formatter=""
                        app:np_max="105"
                        app:np_min="18"
                        android:visibility="gone"
                        app:np_orientation="horizontal"
                        app:np_selectedTextColor="@color/white"
                        app:np_selectedTextSize="22dp"
                        app:np_textColor="#4DFFFFFF"
                        app:np_textSize="@dimen/_16sdp"
                        app:np_value="7" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/stroke_bg_10dp"
                        android:gravity="center_vertical"
                        android:visibility="gone">

                        <EditText
                            android:id="@+id/etUserName"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:layout_weight="1"
                            android:background="@android:color/transparent"
                            android:enabled="false"
                            android:fontFamily="@font/airbnb_cereal_medium"
                            android:hint="@string/enter_username"
                            android:imeOptions="actionNext"
                            android:padding="10dp"
                            android:singleLine="true"
                            android:textAlignment="viewStart"
                            android:textColor="@color/white"
                            android:textColorHint="@color/lightGray" />

                        <ProgressBar
                            android:id="@+id/pd1"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_marginEnd="5dp"
                            android:indeterminateTint="@color/tintColor" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10sp"
                        android:layout_marginTop="15sp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="@string/enter_your_bio"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <androidx.appcompat.widget.AppCompatEditText
                        android:id="@+id/etBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginHorizontal="10sp"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_12dp_stockwhite15"
                        android:fontFamily="@font/airbnbcereal_w_lt"
                        android:gravity="start"
                        android:hint="@string/enter_bio_here"
                        android:minHeight="200dp"
                        android:padding="12dp"
                        android:textAlignment="viewStart"
                        android:textColor="@color/textColor"
                        android:textColorHint="@color/hintColor"
                        android:textSize="16sp"/>

                    <LinearLayout
                        android:id="@+id/lytGender"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="20dp"
                        android:layout_marginTop="20dp"
                        android:gravity="center_vertical"
                        android:orientation="vertical" />
                </androidx.appcompat.widget.LinearLayoutCompat>
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <TextView
            android:id="@+id/tvSubmit"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="15dp"
            android:background="@drawable/gradient_bg_radius_50"
            android:fontFamily="@font/airbnbcereal_w_bd"
            android:gravity="center"
            android:layout_marginHorizontal="15dp"
            android:paddingVertical="15sp"
            android:text="@string/submit"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </LinearLayout>
</layout>