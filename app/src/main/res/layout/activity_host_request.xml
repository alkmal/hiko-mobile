<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/host_request" />
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_above="@+id/txtNext"
            android:layout_below="@+id/topLayout"
            android:scrollbarSize="0dp"
            android:scrollbars="none">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginTop="15dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/_1_self_introduction"
                        android:textColor="@color/white"
                        android:textSize="20sp"
                        android:fontFamily="@font/airbnbcereal_w_bd" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/name"
                            android:textSize="16sp"
                            android:textColor="@color/white_50" />

                        <EditText
                            android:id="@+id/etName"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:hint="@string/enter_your_name"
                            android:imeOptions="actionNext"
                            android:padding="15dp"
                            android:textSize="16dp"
                            android:singleLine="true"
                            android:textAlignment="viewStart"
                            android:textColor="@color/white"
                            android:textColorHint="@color/white_50" />

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:layout_marginTop="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/mobile_number"
                            android:textSize="16sp"
                            android:textColor="@color/white_50" />

                        <EditText
                            android:id="@+id/etMobileNumber"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_gravity="start"
                            android:layout_marginTop="10dp"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:hint="@string/enter_your_name"
                            android:imeOptions="actionNext"
                            android:padding="15dp"
                            android:textSize="16dp"
                            android:singleLine="true"
                            android:textAlignment="viewStart"
                            android:textColor="@color/white"
                            android:textColorHint="@color/white_50"  />

                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="@string/Bio"
                        android:layout_marginTop="10dp"
                        android:textSize="16sp"
                        android:textColor="@color/white_50" />

                    <EditText
                        android:id="@+id/etBio"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="start"
                        android:layout_marginTop="10dp"
                        android:background="@drawable/bg_12dp_stockwhite15"
                        android:fontFamily="@font/airbnbcereal_w_lt"
                        android:hint="@string/enter_bio_here"
                        android:imeOptions="actionNext"
                        android:gravity="start"
                        android:minHeight="143dp"
                        android:padding="15dp"
                        android:textSize="16dp"
                        android:textAlignment="viewStart"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white_50"  />


                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white_10"
                   />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/agency"
                    android:textColor="@color/white"
                    android:includeFontPadding="false"
                    android:layout_marginTop="11dp"
                    android:layout_marginHorizontal="15dp"
                    android:textSize="20sp"
                    android:fontFamily="@font/airbnbcereal_w_bd" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="15dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="@string/_2_agency_code"
                        android:textSize="16sp"
                        android:textColor="@color/white_50" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:layout_marginStart="3dp"
                        android:text="@string/if_you_have"
                        android:textSize="16sp"
                        android:textColor="@color/white_50" />
                </LinearLayout>


                <EditText
                    android:id="@+id/etAgencyCode"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginHorizontal="15dp"
                    android:background="@drawable/bg_12dp_stockwhite15"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:hint="Enter Code"
                    android:imeOptions="actionNext"
                    android:padding="15dp"
                    android:textSize="16dp"
                    android:singleLine="true"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"  />

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white_10" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/my_profile"
                    android:textColor="@color/white"
                    android:layout_marginTop="11dp"
                    android:includeFontPadding="false"
                    android:layout_marginHorizontal="15dp"
                    android:textSize="20sp"
                    android:fontFamily="@font/airbnbcereal_w_bd" />


                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/_3_upload_photos"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="15dp"
                    android:textSize="16sp"
                    android:textColor="@color/white_50" />


                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginBottom="15dp"
                    android:layout_marginTop="10dp">

                    <RelativeLayout
                        android:id="@+id/layFrontPhoto"
                        android:layout_width="142dp"
                        android:layout_height="108dp">

                        <ImageView
                            android:id="@+id/ivSelectedImage"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layUploadFront"
                            android:layout_width="142dp"
                            android:layout_height="108dp"
                            android:background="@drawable/dot_border_strock"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="43dp"
                                android:layout_height="43dp"
                                android:src="@drawable/upload_document" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Upload Photo"
                                android:textColor="@color/lightGray"
                                android:textSize="@dimen/_8sdp" />
                        </LinearLayout>
                    </RelativeLayout>

                    <RelativeLayout
                        android:id="@+id/layBackPhoto"
                        android:layout_width="@dimen/_80sdp"
                        android:layout_height="@dimen/_100sdp"
                        android:layout_marginStart="@dimen/_20sdp"
                        android:visibility="gone">

                        <ImageView
                            android:id="@+id/ivSelectedImageBack"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:scaleType="centerCrop"
                            android:visibility="gone" />

                        <LinearLayout
                            android:id="@+id/layUploadBack"
                            android:layout_width="@dimen/_80sdp"
                            android:layout_height="@dimen/_100sdp"
                            android:background="@drawable/dot_border_strock"
                            android:gravity="center"
                            android:orientation="vertical">

                            <ImageView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:src="@drawable/upload_document" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/_5sdp"
                                android:gravity="center"
                                android:text="@string/id_card_photo"
                                android:textColor="@color/lightGray"
                                android:textSize="@dimen/_8sdp" />
                        </LinearLayout>
                    </RelativeLayout>
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="@color/white_10"
                    />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Bank"
                    android:textColor="@color/white"
                    android:layout_marginTop="11dp"
                    android:includeFontPadding="false"
                    android:layout_marginHorizontal="15dp"
                    android:textSize="20sp"
                    android:fontFamily="@font/airbnbcereal_w_bd" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/_4_bank_details"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="10dp"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <EditText
                    android:id="@+id/etBankDetails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginTop="10dp"
                    android:layout_marginHorizontal="15dp"
                    android:background="@drawable/bg_12dp_stockwhite15"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:hint="@string/enter_your_bank_account_details"
                    android:imeOptions="actionNext"
                    android:padding="15dp"
                    android:textSize="16dp"
                    android:singleLine="true"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"  />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <TextView
            android:id="@+id/txtNext"
            style="@style/commonButtonStyle"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_bg_radius_50"
            android:backgroundTint="@null"
            android:text="@string/next" />
    </RelativeLayout>
</layout>