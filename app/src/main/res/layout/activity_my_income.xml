<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:layout_marginStart="15sp"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/my_income" />

            <ImageView
                android:id="@+id/tvHistory"
                android:layout_width="44sp"
                android:layout_height="44sp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15sp"
                android:src="@drawable/ic_history" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/topLayout"
            android:layout_marginHorizontal="15sp"
            android:orientation="vertical"
            tools:context=".profile.fragment.MyIncomeActivity">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="193sp"
                android:layout_marginVertical="15dp"
                android:layout_marginTop="40dp">

                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/bg_rcoin" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20sp"
                    android:layout_marginTop="20sp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="90sp"
                        android:layout_height="90sp"
                        android:layout_gravity="center"
                        android:src="@drawable/rcoin" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginStart="15sp"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRcoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/rvcoin"
                            android:fontFamily="@font/airbnbcereal_w_xbd"
                            android:text="@string/_0"
                            android:textColor="@color/white"
                            android:textSize="35sp" />

                        <TextView
                            android:id="@+id/rvcoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_10dp"
                            android:backgroundTint="#4D000000"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:text="@string/available_my_r_coins"
                            android:textColor="@color/white_90"
                            android:textSize="15sp" />


                    </LinearLayout>

                </LinearLayout>

                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_centerInParent="true"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginBottom="20dp"
                    app:cardCornerRadius="10sp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="7dp">

                        <TextView
                            android:id="@+id/tvSettingRcoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="10 Coins"
                            android:textColor="@color/rcoin_color"
                            android:textSize="18sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="="
                            android:layout_marginHorizontal="5sp"
                            android:textColor="@color/rcoin_color"
                            android:textSize="18sp" />

                        <TextView
                            android:id="@+id/tvSettingDiamond"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="1 Diamond"
                            android:textColor="@color/rcoin_color"
                            android:textSize="18sp" />
                    </LinearLayout>

                </androidx.cardview.widget.CardView>


            </RelativeLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/airbnbcereal_w_bd"
                android:text="@string/withdraw_r_coin"
                android:textColor="@color/white"
                android:textSize="17sp" />

            <RelativeLayout
                android:id="@+id/rel_withdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp">

                <RelativeLayout
                    android:id="@+id/lytFollowers"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_14sp_white10"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="20dp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:layout_centerVertical="true"
                        android:text="@string/withdrawing_rcoins"
                        android:textColor="#BDFFFFFF"
                        android:textSize="15sp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_gravity="end"
                        app:cardCornerRadius="12sp"
                        app:cardBackgroundColor="#652EBE"
                        android:layout_marginVertical="@dimen/_3sdp"
                        android:layout_marginEnd="@dimen/_3sdp">

                    <TextView
                        android:id="@+id/tvWithdrawingRcoin"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_bd"
                        android:paddingHorizontal="20sp"
                        android:paddingVertical="7sp"
                        android:text="0"
                        android:textColor="@color/white"
                        android:textSize="24sp" />

                    </androidx.cardview.widget.CardView>
                </RelativeLayout>


            </RelativeLayout>

            <TextView
                android:id="@+id/tvMaximumWithdraw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/airbnbcereal_w_md"
                android:text="*Maximum Withdraw :1200"
                android:layout_marginTop="10sp"
                android:textColor="@color/red"
                android:textSize="11sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/btnConvert"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/bg_convert_diamond"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:gravity="center"
                    android:paddingVertical="15sp"
                    android:text="@string/convert_to_diamond"
                    android:textColor="@color/white"
                    android:textSize="17sp" />

                <TextView
                    android:id="@+id/btnCashout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:background="@drawable/bg_convert_diamond"
                    android:backgroundTint="@color/white"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:gravity="center"
                    android:paddingVertical="15sp"
                    android:text="@string/cash_out"
                    android:textColor="@color/black"
                    android:textSize="17sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_20sdp"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:text="@string/what_is_coins"
                    android:textSize="18sp"
                    android:textColor="@color/white" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:fontFamily="@font/airbnbcereal_w_bk"
                    android:paddingStart="7sp"
                    android:lineSpacingExtra="@dimen/_1sdp"
                    android:text="@string/what_is_rcoin"
                    android:textColor="@color/white_60"
                    android:textSize="13sp" />
            </LinearLayout>
        </LinearLayout>
    </RelativeLayout>
</layout>