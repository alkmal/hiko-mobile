<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        tools:context=".postDummies.FeedGridActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="30sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:layout_marginStart="15sp"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/user_level" />

        </RelativeLayout>

            <LinearLayout
                android:id="@+id/layDetails"
                android:layout_width="match_parent"
                android:layout_height="110dp"
                android:layout_below="@+id/topLayout"
                android:layout_marginTop="15dp"
                android:layout_marginHorizontal="15dp"
                android:background="@drawable/bg_diamond_history"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/myLevelImage"
                    android:layout_width="90dp"
                    android:layout_height="90dp"
                    android:layout_marginHorizontal="15dp"
                    android:src="@drawable/ic_level1"
                    android:layout_gravity="center" />
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:orientation="vertical">

                <TextView
                    android:id="@+id/tvMyLevel"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:fontFamily="@font/airbnbcereal_w_xbd"
                    android:text="@string/level_1"
                    android:textColor="@color/white"
                    android:textSize="25sp" />

                <TextView
                    android:id="@+id/tvSpentCoin"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:text="@string/you_ve_spent_0_rcoins"
                    android:textColor="@color/white_90"
                    android:textSize="15sp" />
                </LinearLayout>
            </LinearLayout>

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/layDetails"
            android:layout_marginTop="30dp"
            android:background="@drawable/bg_level_card">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvFeed"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginVertical="@dimen/_8sdp"
                android:orientation="vertical"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                tools:listitem="@layout/item_level" />

            <com.facebook.shimmer.ShimmerFrameLayout
                android:id="@+id/shimmer"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginVertical="@dimen/_8sdp"
                app:shimmer_base_color="@color/shimmerColor"
                app:shimmer_colored="false"
                app:shimmer_highlight_color="@color/white"
                tools:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="visible"
                    android:orientation="vertical">

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />

                    <include layout="@layout/shimmer_item_level" />
                </LinearLayout>
            </com.facebook.shimmer.ShimmerFrameLayout>
        </RelativeLayout>

        <include layout="@layout/layout_no_internet" />
    </RelativeLayout>
</layout>