<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="loader"
            type="com.codder.ultimate.MyLoader" />
    </data>

    <RelativeLayout
        android:id="@+id/main"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        tools:context=".profile.activity.MyPostsActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/my_posts" />
        </RelativeLayout>

        <com.scwang.smart.refresh.layout.SmartRefreshLayout
            android:id="@+id/swipe_refresh"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/topLayout">

            <com.scwang.smart.refresh.header.ClassicsHeader
                android:id="@+id/header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@android:color/transparent"
                app:layout_srlSpinnerStyle="Translate"
                app:srlAccentColor="@color/pink"
                app:srlDrawableArrow="@drawable/swipe_arrow"
                app:srlEnableLastTime="false"
                app:srlEnablePullToCloseTwoLevel="false"
                app:srlEnableTwoLevel="false"
                app:srlPrimaryColor="@color/transparent" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvFeed"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="3"
                    tools:listitem="@layout/item_feed_grid_list" />

                <com.facebook.shimmer.ShimmerFrameLayout
                    android:id="@+id/shimmer"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginHorizontal="5dp"
                    android:visibility="@{loader.isFirstTimeLoading?View.VISIBLE : View.GONE}"
                    app:shimmer_base_color="@color/shimmerColor"
                    app:shimmer_colored="false"
                    app:shimmer_highlight_color="@color/white"
                    tools:visibility="visible">

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:orientation="vertical">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="127dp"
                                android:layout_margin="5dp"
                                android:layout_marginTop="10dp"
                                android:background="@drawable/bg_10dp_purewhite"
                                android:backgroundTint="@color/shimmerColor" />
                        </LinearLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.facebook.shimmer.ShimmerFrameLayout>
            </RelativeLayout>

            <com.scwang.smart.refresh.footer.ClassicsFooter
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:gravity="center" />
        </com.scwang.smart.refresh.layout.SmartRefreshLayout>

        <RelativeLayout
            android:id="@+id/layoutNoData"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:layout_marginTop="150dp"
            android:visibility="@{loader.noData?View.VISIBLE : View.GONE}">

            <include layout="@layout/lyt_no_data" />
        </RelativeLayout>

        <include layout="@layout/layout_no_internet" />
    </RelativeLayout>
</layout>