<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        tools:context=".profile.fragment.MyWalletActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:layout_marginStart="10sp"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/my_wallet" />

            <ImageView
                android:id="@+id/tvHistory"
                android:layout_width="44sp"
                android:layout_height="44sp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15sp"
                android:src="@drawable/ic_history"/>
        </RelativeLayout>

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/topLayout">

            <LinearLayout
                android:id="@+id/layoutMain"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginHorizontal="10sp"
                android:orientation="vertical">

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/layWallet"
                    android:layout_width="match_parent"
                    android:layout_height="80sp"
                    android:layout_marginTop="15sp"
                    android:background="@drawable/bg_wallet"
                    android:gravity="center_vertical"
                    android:padding="@dimen/_10sdp">

                    <ImageView
                        android:layout_width="52sp"
                        android:layout_height="60sp"
                        android:src="@drawable/diamond" />

                    <RelativeLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentStart="true"
                        android:layout_centerVertical="true"
                        android:layout_marginStart="7dp">

                        <TextView
                            android:id="@+id/tvcoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bk"
                            android:text="@string/my_diamonds"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <TextView
                            android:id="@+id/tvMyCoins"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@+id/tvcoin"
                            android:fontFamily="@font/airbnbcereal_w_blk"
                            android:text="@string/_0"
                            android:textColor="@color/white"
                            android:textSize="20sp" />
                    </RelativeLayout>
                </androidx.appcompat.widget.LinearLayoutCompat>

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/lytCoinSeller"
                        android:layout_width="match_parent"
                        android:layout_height="50sp"
                        android:layout_marginEnd="8sp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_offlinerecharge"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/_5sdp">

                        <ImageView
                            android:layout_width="20sp"
                            android:layout_height="23sp"
                            android:src="@drawable/diamond" />

                        <TextView
                            android:id="@+id/tvCoinseller"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="@string/offline_recharge"
                            android:layout_marginStart="5dp"
                            android:textColor="@color/white"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/layoutMyIncome"
                        android:layout_width="match_parent"
                        android:layout_height="50dp"
                        android:layout_marginStart="8sp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_offlinerecharge"
                        android:gravity="center"
                        android:orientation="horizontal"
                        android:paddingVertical="@dimen/_5sdp">

                        <ImageView
                            android:layout_width="22sp"
                            android:layout_height="22sp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_income_wallet" />

                        <TextView
                            android:id="@+id/tvMyIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="@string/my_income"
                            android:layout_gravity="center"
                            android:includeFontPadding="false"
                            android:layout_marginStart="5sp"
                            android:textColor="@color/white"
                            android:textSize="16sp" />
                    </LinearLayout>
                </androidx.appcompat.widget.LinearLayoutCompat>

                <RelativeLayout
                    android:id="@+id/layPopularPurchase"
                    android:layout_width="match_parent"
                    android:layout_height="162sp"
                    android:layout_marginTop="@dimen/_12sdp"
                    android:background="@drawable/purchase_bg"
                    android:layoutDirection="ltr"
                    android:orientation="vertical">

                    <LinearLayout
                        android:layout_width="@dimen/_100sdp"
                        android:layout_height="@dimen/_100sdp"
                        android:gravity="center">

                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:layout_width="@dimen/_200sdp"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="@dimen/_50sdp"
                            android:background="@drawable/plan_gradient"
                            android:backgroundTint="#FFC918"
                            android:gravity="center"
                            android:rotation="320">

                            <TextView
                                android:id="@+id/tvTag"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginEnd="@dimen/_65sdp"
                                android:fontFamily="@font/airbnbcereal_w_xbd"
                                android:paddingVertical="@dimen/_1sdp"
                                android:text="@string/best_plan"
                                android:textAllCaps="true"
                                android:textColor="#9E4C0C"
                                android:textSize="11sp" />
                        </androidx.appcompat.widget.LinearLayoutCompat>
                    </LinearLayout>

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/_35sdp"
                        android:layout_marginTop="20sp"
                        android:gravity="center_vertical">

                        <ImageView
                            android:id="@+id/ivDiamond"
                            android:layout_width="64sp"
                            android:layout_height="72sp"
                            android:layout_centerVertical="true"
                            android:src="@drawable/diamond" />

                        <TextView
                            android:id="@+id/tvBestPlan"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:layout_marginTop="@dimen/_10sdp"
                            android:layout_toEndOf="@+id/ivDiamond"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/best_recharge_plan"
                            android:textColor="@color/white_90"
                            android:textSize="13sp" />

                        <TextView
                            android:id="@+id/tvPopulatPlanCoin"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_below="@id/tvBestPlan"
                            android:layout_gravity="center"
                            android:layout_marginStart="@dimen/_5sdp"
                            android:layout_marginTop="@dimen/_5sdp"
                            android:layout_toEndOf="@+id/ivDiamond"
                            android:fontFamily="@font/airbnbcereal_w_xbd"
                            android:text="15152"
                            android:textColor="@color/wallet_yellow"
                            android:textSize="32sp" />

                        <androidx.cardview.widget.CardView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:layout_gravity="center"
                            android:layout_marginEnd="@dimen/_10sdp"
                            app:cardCornerRadius="@dimen/_15sdp">

                            <LinearLayout
                                android:layout_width="85sp"
                                android:layout_height="35sp"
                                android:background="@drawable/bg_wallet_text"
                                android:gravity="center"
                                android:paddingHorizontal="@dimen/_10sdp">

                                <TextView
                                    android:id="@+id/tvPopularPlanAmount"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:fontFamily="@font/airbnbcereal_w_bd"
                                    android:gravity="center"
                                    android:text="$ 102"
                                    android:textColor="@color/white"
                                    android:textSize="16sp" />
                            </LinearLayout>
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_alignParentBottom="true"
                        android:background="@drawable/bottom_radius_bg"
                        android:gravity="center">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawablePadding="@dimen/_10sdp"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:padding="@dimen/_10sdp"
                            android:text="@string/purchase_recharge_plan"
                            android:textColor="@color/white"
                            android:textSize="16sp"
                            app:drawableEndCompat="@drawable/icon_double_arrow"
                            app:drawableTint="@color/white" />
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </RelativeLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/best_recharge_plan"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rvRecharge"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:layout_marginBottom="10sp"
                    android:orientation="vertical"
                    app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                    app:spanCount="3"
                    tools:listitem="@layout/item_purchase_coin" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/topLayout"
            android:visibility="gone"
            app:shimmer_base_color="@color/shimmerColor"
            app:shimmer_colored="true"
            app:shimmer_highlight_color="@color/white">

            <include layout="@layout/shimmer_activity_my_wallet" />
        </com.facebook.shimmer.ShimmerFrameLayout>
    </RelativeLayout>
</layout>