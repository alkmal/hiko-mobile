<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        tools:context=".profile.activity.RecordActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/history" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/topLayout"
            android:layout_marginHorizontal="15sp"
            android:orientation="vertical">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_10sdp"
                android:paddingVertical="5sp"
                android:background="@drawable/bg_datepicker"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:paddingHorizontal="15sp"
                    android:layout_marginTop="10sp"
                    android:text="@string/select_record_duration"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingHorizontal="15sp"
                    android:paddingVertical="10sp">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="5sp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/start_date_"
                            android:textColor="@color/white_50"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:id="@+id/lytDate1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12sp"
                            android:paddingVertical="12sp">

                            <TextView
                                android:id="@+id/tvDate1"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/airbnbcereal_w_bk"
                                android:text="DD/MM/YYYY"
                                android:textColor="@color/white"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginStart="5sp"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/end_date_"
                            android:textColor="@color/white_50"
                            android:textSize="16sp" />

                        <LinearLayout
                            android:id="@+id/lytDate2"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5sp"
                            android:background="@drawable/bg_12dp_stockwhite15"
                            android:orientation="horizontal"
                            android:paddingHorizontal="12sp"
                            android:paddingVertical="12sp">

                            <TextView
                                android:id="@+id/tvDate2"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/airbnbcereal_w_bk"
                                android:text="DD/MM/YYYY"
                                android:textColor="@color/white"
                                android:textSize="16sp" />
                        </LinearLayout>
                    </LinearLayout>
                </androidx.appcompat.widget.LinearLayoutCompat>
            </androidx.appcompat.widget.LinearLayoutCompat>

            <LinearLayout
                android:id="@+id/lytDiamonds"
                android:layout_width="match_parent"
                android:layout_height="186sp"
                android:layout_marginTop="@dimen/_15sdp"
                android:background="@drawable/bg_diamond_record"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10sp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="52sp"
                        android:layout_height="60sp"
                        android:backgroundTint="@color/charcoalGray"
                        android:src="@drawable/diamond" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_blk"
                            android:text="Diamond Coin"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bk"
                            android:text="@string/record"
                            android:textColor="@color/white"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="10sp"
                        android:paddingVertical="10sp"
                        android:background="@drawable/bg_radius13_whitestrock12">

                    <ImageView
                        android:layout_width="24sp"
                        android:layout_height="24sp"
                        android:layout_gravity="center_vertical"
                        android:backgroundTint="@color/charcoalGray"
                        android:src="@drawable/icon_redirect"
                         />

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp"
                    android:layout_weight="1.5"
                    android:gravity="center"
                    android:background="@drawable/bg_radius19_whitestrock12"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDimondsIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1452"
                            android:textColor="@color/white"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/income"
                            android:textColor="@color/white_48"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="52sp"
                        android:background="@color/white_10" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDiamondsOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1253"
                            android:textColor="@color/white"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/outcome"
                            android:textColor="@color/white_48"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytRcoins"
                android:layout_width="match_parent"
                android:layout_height="186sp"
                android:layout_marginTop="@dimen/_15sdp"
                android:background="@drawable/bg_rcoin_record"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10sp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">

                    <ImageView
                        android:layout_width="52sp"
                        android:layout_height="52sp"
                        android:backgroundTint="@color/charcoalGray"
                        android:src="@drawable/rcoin" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:layout_marginStart="10dp"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_blk"
                            android:text="R-Coins"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bk"
                            android:text="@string/record"
                            android:textColor="@color/white"
                            android:textSize="16sp" />
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:paddingHorizontal="10sp"
                        android:paddingVertical="10sp"
                        android:background="@drawable/bg_radius13_whitestrock12">

                        <ImageView
                            android:layout_width="24sp"
                            android:layout_height="24sp"
                            android:layout_gravity="center_vertical"
                            android:backgroundTint="@color/charcoalGray"
                            android:src="@drawable/icon_redirect"
                            />

                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp"
                    android:layout_weight="1.5"
                    android:gravity="center"
                    android:background="@drawable/bg_radius19_whitestrock12"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/lytFollowing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRcoinIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1452"
                            android:textColor="@color/white"
                            android:textSize="22sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/income"
                            android:textColor="@color/white_48"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="52sp"
                        android:background="@color/white_10" />

                    <LinearLayout
                        android:id="@+id/lytFollowers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRcoinOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1452"
                            android:textColor="@color/white"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/outcome"
                            android:textColor="@color/white_48"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <include
            android:id="@+id/lytDatePicker"
            layout="@layout/bottom_sheet_datepiker"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:background="@drawable/bg_bottom_sheet_top_corner_radius"
            android:visibility="gone" />

        <com.facebook.shimmer.ShimmerFrameLayout
            android:id="@+id/shimmer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:shimmer_base_color="@color/shimmerColor"
            app:shimmer_colored="false"
            app:shimmer_highlight_color="@color/white"
            tools:visibility="gone">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <include
                    layout="@layout/shimmer_activity_record"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_alignParentBottom="true" />
            </RelativeLayout>
        </com.facebook.shimmer.ShimmerFrameLayout>
    </RelativeLayout>
</layout>