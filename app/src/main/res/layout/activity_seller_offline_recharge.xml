<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        tools:context=".profile.activity.SellerOfflineRechargeActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:layout_marginStart="15sp"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                android:id="@+id/tvTitle"
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/offline_recharge" />

            <ImageView
                android:id="@+id/tvHistory"
                android:layout_width="44sp"
                android:layout_height="44sp"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="15sp"
                android:src="@drawable/ic_history" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@id/btnTopup"
            android:layout_below="@+id/topLayout"
            android:orientation="vertical">

            <RelativeLayout
                android:id="@+id/cardTemp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="10dp"
                android:layout_marginTop="15dp"
                android:elevation="5dp"
                app:cardCornerRadius="14dp">

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="80dp"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:background="@drawable/bg_diamond_history">

                    <ImageView
                        android:id="@+id/ivDiamond"
                        android:layout_width="52dp"
                        android:layout_height="60dp"
                        android:layout_marginStart="15dp"
                        android:layout_centerVertical="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/diamond" />

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:layout_marginHorizontal="@dimen/_10sdp"
                        android:layout_toEndOf="@id/ivDiamond"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bk"
                            android:text="@string/my_diamonds"
                            android:textColor="@color/white"
                            android:textSize="16sp" />

                        <RelativeLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/tvMyCoins"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:fontFamily="@font/airbnbcereal_w_blk"
                                android:text="@string/_0"
                                android:textColor="@color/white"
                                android:textSize="20dp" />

                            <com.facebook.shimmer.ShimmerFrameLayout
                                android:id="@+id/shimmer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                app:shimmer_base_color="@color/shimmerColor"
                                app:shimmer_colored="false"
                                app:shimmer_highlight_color="@color/white"
                                tools:visibility="gone">

                                <LinearLayout
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:orientation="vertical">

                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/_5sdp"
                                        android:background="@drawable/bg_10dp_purewhite"
                                        android:backgroundTint="@color/shimmerColor"
                                        android:ellipsize="end"
                                        android:fontFamily="@font/airbnb_cereal_bold"
                                        android:singleLine="true"
                                        android:text="11111111111"
                                        android:textColor="@color/shimmerColor"
                                        android:textSize="@dimen/_24sdp" />
                                </LinearLayout>
                            </com.facebook.shimmer.ShimmerFrameLayout>
                        </RelativeLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </RelativeLayout>
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="15dp"
                android:layout_marginTop="15dp"
                android:gravity="end"
                android:orientation="vertical">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/user_id"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp">

                    <EditText
                        android:id="@+id/etUserId"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:background="@drawable/bg_12dp_stockwhite15"
                        android:fontFamily="@font/airbnbcereal_w_lt"
                        android:hint="@string/enter_user_id"
                        android:imeOptions="actionNext"
                        android:inputType="textNoSuggestions"
                        android:paddingHorizontal="@dimen/_10sdp"
                        android:singleLine="true"
                        android:text=""
                        android:textAlignment="viewStart"
                        android:textColor="@color/white"
                        android:textColorHint="@color/white_50"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/ivFind"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="@dimen/_10sdp"
                        android:src="@drawable/icon_blue_tick" />
                </RelativeLayout>

                <TextView
                    android:id="@+id/tvUserName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="start"
                    android:layout_marginHorizontal="5dp"
                    android:layout_marginTop="3dp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text=""
                    android:textSize="12sp"
                    android:textColor="@color/white"
                    android:visibility="gone" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/diamonds"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp"
                    android:background="@drawable/bg_12dp_stockwhite15"
                    android:layout_marginTop="@dimen/_5sdp">

                    <ImageView
                        android:layout_width="17dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="10dp"
                        android:layout_centerVertical="true"
                        android:scaleType="fitCenter"
                        android:src="@drawable/diamond" />

                <EditText
                    android:id="@+id/etCoin"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_40sdp"
                    android:background="@color/transparent"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:hint="@string/enter_diamonds"
                    android:imeOptions="actionNext"
                    android:inputType="number"
                    android:paddingHorizontal="10dp"
                    android:singleLine="true"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"
                    android:textSize="16sp" />

                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/note"
                    android:textSize="16sp"
                    android:textColor="@color/white" />

                <EditText
                    android:id="@+id/etNote"
                    android:layout_width="match_parent"
                    android:layout_height="143dp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:background="@drawable/bg_12dp_stockwhite15"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:hint="@string/enter_note_here"
                    android:imeOptions="actionNext"
                    android:inputType="textPersonName|textCapWords"
                    android:paddingHorizontal="15dp"
                    android:singleLine="true"
                    android:gravity="start"
                    android:paddingVertical="15dp"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"
                    android:textSize="16sp" />
            </LinearLayout>
        </LinearLayout>

        <TextView
            android:id="@+id/btnTopup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_marginBottom="15dp"
            android:layout_marginHorizontal="15dp"
            android:background="@drawable/gradient_bg_radius_50"
            android:fontFamily="@font/airbnbcereal_w_bd"
            android:gravity="center"
            android:paddingVertical="15sp"
            android:text="@string/top_up"
            android:textColor="@color/white"
            android:textSize="18sp" />

    </RelativeLayout>
</layout>