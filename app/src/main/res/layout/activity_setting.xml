<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

        <import type="android.view.View" />

        <variable
            name="isLoading"
            type="Boolean" />
    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        android:layoutDirection="locale"
        tools:context=".profile.activity.SettingActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:layout_marginStart="20sp"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/settings" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/tvVersion"
            android:layout_below="@id/topLayout"
            android:layout_marginTop="@dimen/_10sdp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layoutDirection="locale"
                android:textDirection="locale"
                android:orientation="vertical">



                <LinearLayout
                    android:id="@+id/RelNotification"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/_5sdp"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:id="@+id/tvNotification"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_notification" />

                    <TextView
                        android:id="@+id/notification"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:textAlignment="viewStart"
                        android:text="@string/notification" />

                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switchNotification"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center"
                        android:layout_marginEnd="10sp"
                        android:checked="false"
                        android:thumb="@drawable/custom_thumb"
                        app:track="@drawable/custom_track" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:id="@+id/lytSupport"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_support" />

                    <TextView
                        android:id="@+id/tvHaveIssue"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/have_an_issue"
                        app:drawableEndCompat="@drawable/icon_redirect" />

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:id="@+id/lytComplains"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_customer_satisfaction" />

                    <TextView
                        android:id="@+id/tvMyComplain"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/my_complains"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:id="@+id/lytLanguage"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="6dp">

                    <ImageView
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_select_language" />

                    <TextView
                        android:id="@+id/tvLanguage"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/select_language"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:onClick="onClickTerms"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp">


                    <ImageView
                        android:id="@+id/tvTerms"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_terms_condition" />

                    <TextView
                        android:id="@+id/termsOfService"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/terms_of_service"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:onClick="onClickPrivacy"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp">

                    <ImageView
                        android:id="@+id/tvPolicy"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_privacy_policy" />

                    <TextView
                        android:id="@+id/privacyPolicy"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/privacy_policy"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:onClick="onClickAbout"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:id="@+id/tvAboutUs"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_about_us" />

                    <TextView
                        android:id="@+id/aboutUs"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/about_us"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1sp"
                    android:layout_marginHorizontal="15sp"
                    android:layout_marginVertical="10sp"
                    android:background="@color/white_20"/>

                <LinearLayout
                    android:id="@+id/btnLogout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="20dp"
                    android:orientation="horizontal"
                    android:padding="@dimen/_5sdp"
                    android:paddingHorizontal="10dp">

                    <ImageView
                        android:id="@+id/tvLogout"
                        android:layout_width="@dimen/_40sdp"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginStart="15sp"
                        android:src="@drawable/icon_setting_logout" />

                    <TextView
                        android:id="@+id/logout"
                        style="@style/commonTextStyle"
                        android:layout_weight="1"
                        android:text="@string/log_out"
                        app:drawableEndCompat="@drawable/icon_redirect" />
                </LinearLayout>

            </LinearLayout>
        </ScrollView>

        <TextView
            android:id="@+id/tvVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_centerHorizontal="true"
            android:layout_gravity="center"
            android:layout_marginTop="@dimen/_10sdp"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/airbnb_cereal_bold"
            android:text=""
            android:textColor="@color/white" />

        <include layout="@layout/layout_no_internet" />
    </RelativeLayout>
</layout>