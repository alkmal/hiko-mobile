<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/app_main_bg"
        android:fitsSystemWindows="true"
        android:orientation="vertical"
        tools:context=".live.activity.UploadPostActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:onClick="onClickBack" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:text="@string/upload_relite" />
        </RelativeLayout>

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_above="@id/btnPost"
            android:layout_below="@+id/topLayout">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp">

                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:visibility="visible">

                        <androidx.cardview.widget.CardView
                            android:layout_width="160dp"
                            android:layout_height="240dp"
                            android:layout_centerHorizontal="true"
                            app:cardBackgroundColor="@color/transparent"
                            app:cardCornerRadius="20dp">

                            <ImageView
                                android:id="@+id/imageview"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:scaleType="centerCrop"
                                android:src="@drawable/girl" />
                        </androidx.cardview.widget.CardView>
                    </RelativeLayout>

                </LinearLayout>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/add_caption"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <com.codder.ultimate.socialView.SocialEditText
                    android:id="@+id/descriptionView"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="7dp"
                    android:background="@drawable/bg16dp_strockwhite16"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:gravity="start"
                    android:hint="@string/add_caption_with_hashtags_and_mentions"
                    android:minHeight="130dp"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp"
                    android:textColor="@color/white"
                    android:textColorHint="@color/white_50"
                    android:textSize="16sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="15dp"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:text="@string/select_option"
                    android:textColor="@color/white"
                    android:textSize="16sp" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:orientation="vertical">

                    <LinearLayout
                        android:id="@+id/lytLocation"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_16dp"
                        android:backgroundTint="@color/white_10"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/location" />

                        <TextView
                           android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:textColor="@color/white"
                            android:layout_marginStart="10dp"
                            android:singleLine="true"
                            android:text="@string/location" />


                        <TextView
                            android:id="@+id/tvLocation"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_weight="1"
                            android:ellipsize="marquee"
                            android:layout_marginEnd="7dp"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:gravity="end"
                            android:textSize="14sp"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/locationArrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/icon_redirect" />
                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/lytPrivacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_16dp"
                        android:backgroundTint="@color/white_10"
                        android:layout_marginTop="15dp"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <ImageView
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/eye" />

                        <TextView
                            android:id="@+id/showToLyt"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:textColor="@color/white"
                            android:layout_marginStart="10dp"
                            android:singleLine="true"
                            android:text="@string/show_to" />

                        <TextView
                            android:id="@+id/tvPrivacy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center"
                            android:layout_weight="1"
                            android:ellipsize="marquee"
                            android:layout_marginEnd="7dp"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:gravity="end"
                            android:textSize="14sp"
                            android:text="@string/public_"
                            android:marqueeRepeatLimit="marquee_forever"
                            android:scrollHorizontally="true"
                            android:singleLine="true"
                            android:textColor="@color/white" />

                        <ImageView
                            android:id="@+id/showtoarrow"
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:layout_gravity="center"
                            android:layout_marginEnd="10dp"
                            android:src="@drawable/icon_redirect" />
                    </LinearLayout>


                    <RelativeLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_16dp"
                        android:backgroundTint="@color/white_10"
                        android:layout_marginTop="15dp"
                        android:orientation="horizontal"
                        android:paddingVertical="10dp">

                        <ImageView
                            android:id="@+id/ivComment"
                            android:layout_width="42dp"
                            android:layout_height="42dp"
                            android:layout_marginStart="10dp"
                            android:src="@drawable/ic_comments" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_gravity="center_vertical"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:textColor="@color/white"
                            android:layout_toEndOf="@id/ivComment"
                            android:layout_centerVertical="true"
                            android:layout_marginStart="10dp"
                            android:singleLine="true"
                            android:text="@string/allow_comments" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switchComments"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginHorizontal="10dp"
                            android:layout_alignParentEnd="true"
                            android:layout_centerVertical="true"
                            android:checked="true"
                            android:layout_gravity="center|end"
                            android:thumb="@drawable/custom_thumb"
                            app:track="@drawable/custom_track" />
                    </RelativeLayout>
                </androidx.appcompat.widget.LinearLayoutCompat>


            </androidx.appcompat.widget.LinearLayoutCompat>
        </ScrollView>


        <TextView
            android:id="@+id/btnPost"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:layout_marginHorizontal="15dp"
            android:layout_marginBottom="15dp"
            android:layout_alignParentBottom="true"
            android:background="@drawable/gradient_bg_radius_50"
            android:fontFamily="@font/airbnbcereal_w_bd"
            android:gravity="center"
            android:paddingVertical="15sp"
            android:text="@string/upload"
            android:textColor="@color/white"
            android:textSize="18sp" />

        <ProgressBar
            android:id="@+id/loader"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:layout_centerInParent="true"
            android:layout_centerVertical="true"
            android:indeterminateTint="@color/tintColor"
            android:visibility="gone" />

        <include layout="@layout/layout_no_internet" />
    </RelativeLayout>
</layout>
