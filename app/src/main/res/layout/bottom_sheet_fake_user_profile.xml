<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="end"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:contentDescription="@string/close"
            android:focusable="true"
            android:src="@drawable/ic_close_profile" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:background="@drawable/bg_bottom_sheet_top_corner_radius"
            android:clickable="true"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:focusable="true"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical">

                <com.codder.ultimate.utils.UserProfileImageView
                    android:id="@+id/imgUser"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_marginTop="-40dp" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="10dp"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:singleLine="true"
                    android:text="@string/dummy_name"
                    android:textColor="@color/white"
                    android:textSize="18sp" />

                <androidx.appcompat.widget.LinearLayoutCompat
                    android:id="@+id/layoutUsername"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4sp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/userId"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_lt"
                        android:gravity="start"
                        android:text="@string/dummy_id"
                        android:textAlignment="viewStart"
                        android:textColor="@color/white_60"
                        android:textSize="14sp" />

                    <ImageView
                        android:id="@+id/copy"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:layout_gravity="center"
                        android:layout_marginStart="3dp"
                        android:padding="1dp"
                        android:src="@drawable/icon_copy" />
                </androidx.appcompat.widget.LinearLayoutCompat>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="4dp"
                    android:layout_marginBottom="@dimen/_7sdp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCountry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_20dp"
                        android:backgroundTint="@color/white_10"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:paddingHorizontal="15sp"
                        android:paddingVertical="5sp"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        tools:text="@string/india" />

                    <TextView
                        android:id="@+id/tvLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10sp"
                        android:background="@drawable/bg_20dp"
                        android:backgroundTint="@color/white_10"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:paddingHorizontal="15sp"
                        android:paddingVertical="5sp"
                        android:text="Lv. 1"
                        android:textColor="@color/white"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_20dp"
                        android:backgroundTint="@color/white_10"
                        android:paddingHorizontal="15sp"
                        android:paddingVertical="5sp">

                        <ImageView
                            android:id="@+id/ivGender"
                            android:layout_width="12sp"
                            android:layout_height="12sp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_female" />

                        <TextView
                            android:id="@+id/tvAge"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="2sp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="20"
                            android:textColor="@color/white"
                            android:textSize="12sp" />
                    </LinearLayout>

                </LinearLayout>


                <androidx.appcompat.widget.LinearLayoutCompat
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp">

                    <TextView
                        android:id="@+id/tvType"
                        style="@style/commonLabelStyle"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:backgroundTint="#ED6B0C"
                        android:drawablePadding="@dimen/_5sdp"
                        android:text="@string/agency"
                        android:textSize="@dimen/_10sdp"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_agency" />

                    <TextView
                        android:id="@+id/tvVIPType"
                        style="@style/commonLabelStyle"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:backgroundTint="#FEAD2A"
                        android:drawablePadding="@dimen/_5sdp"
                        android:text="@string/vip"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_crown" />

                    <TextView
                        android:id="@+id/tvCoinType"
                        style="@style/commonLabelStyle"
                        android:layout_marginStart="@dimen/_5sdp"
                        android:backgroundTint="@color/purple_color"
                        android:drawablePadding="@dimen/_5sdp"
                        android:text="@string/bd"
                        android:visibility="gone"
                        app:drawableStartCompat="@drawable/ic_agency" />

                </androidx.appcompat.widget.LinearLayoutCompat>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:paddingVertical="10dp">

                    <LinearLayout
                        android:id="@+id/lytFollowers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvFollowrs"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="250"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:text="@string/followers"
                            android:textColor="@color/white"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width=".3dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_10dp_purewhite"
                        android:backgroundTint="@color/white_30" />

                    <LinearLayout
                        android:id="@+id/lytMyVideos2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvVideos"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="50"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:text="@string/shorts"
                            android:textColor="@color/white"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width=".3dp"
                        android:layout_height="26dp"
                        android:layout_gravity="center"
                        android:background="@drawable/bg_10dp_purewhite"
                        android:backgroundTint="@color/white_30" />

                    <LinearLayout
                        android:id="@+id/lytMyPost2"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvPosts"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:text="17"
                            android:textColor="@color/white"
                            android:textSize="20sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_lt"
                            android:text="@string/posts"
                            android:textColor="@color/white"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layOption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_alignParentBottom="true"
                    android:layout_marginTop="10dp"
                    android:background="@drawable/bg_25dp_topradius"
                    android:orientation="horizontal"
                    android:paddingHorizontal="15dp"
                    android:paddingVertical="15dp"
                    android:weightSum="3">

                    <RelativeLayout
                        android:id="@+id/lytFollowUnfollow"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:background="@drawable/bg_follow"
                        android:gravity="center"
                        android:paddingHorizontal="12sp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10sp">

                            <ImageView
                                android:id="@+id/ivFollow"
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/guest_profile_follow" />

                            <TextView
                                android:id="@+id/tvFollowStatus"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/airbnbcereal_w_md"
                                android:paddingStart="5sp"
                                android:text="@string/follow"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                        </LinearLayout>

                        <ProgressBar
                            android:id="@+id/pdFollow"
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:layout_centerInParent="true"
                            android:clickable="false"
                            android:focusable="false"
                            android:indeterminateTint="@color/white"
                            android:visibility="gone" />
                    </RelativeLayout>

                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:id="@+id/btnMessage"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginHorizontal="10sp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_20dp"
                        android:backgroundTint="@color/green_message"
                        android:gravity="center"
                        android:paddingHorizontal="12sp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10sp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_message" />

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/airbnbcereal_w_md"
                                android:paddingStart="5sp"
                                android:text="@string/message"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                        </LinearLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>

                    <RelativeLayout
                        android:id="@+id/btnBlock"
                        android:layout_width="0dp"
                        android:layout_height="@dimen/_30sdp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_20dp"
                        android:backgroundTint="@color/red"
                        android:gravity="center"
                        android:paddingHorizontal="10sp">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:paddingVertical="10sp">

                            <ImageView
                                android:layout_width="18dp"
                                android:layout_height="18dp"
                                android:src="@drawable/ic_block" />

                            <TextView
                                android:id="@+id/tvBlock"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:fontFamily="@font/airbnbcereal_w_md"
                                android:paddingStart="5sp"
                                android:text="@string/block"
                                android:textColor="@color/white"
                                android:textSize="12sp" />

                        </LinearLayout>


                        <ProgressBar
                            android:id="@+id/pdBlock"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:layout_centerInParent="true"
                            android:clickable="false"
                            android:focusable="false"
                            android:indeterminateTint="@color/white"
                            android:visibility="gone" />
                    </RelativeLayout>
                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

    </FrameLayout>
</layout>