<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:orientation="vertical">

        <ImageView
            android:id="@+id/ivClose"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_gravity="end"
            android:layout_marginBottom="-30dp"
            android:layout_marginEnd="10dp"
            android:clickable="true"
            android:focusable="true"
            android:contentDescription="@string/close"
            android:src="@drawable/ic_close_profile" />

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="50dp"
            android:background="@drawable/bg_bottom_sheet_top_corner_radius"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:orientation="vertical">



        <LinearLayout
            android:id="@+id/detailLay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:layout_marginTop="-40dp"
            android:layout_centerHorizontal="true"
            android:orientation="vertical">

            <com.codder.ultimate.utils.UserProfileImageView
                android:id="@+id/userImg"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_gravity="center"
                android:layout_marginVertical="@dimen/_3sdp" />

            <TextView
                android:id="@+id/userName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="10dp"
                android:fontFamily="@font/airbnbcereal_w_bd"
                android:singleLine="true"
                android:text="@string/dummy_name"
                android:textColor="@color/white"
                android:textSize="18sp" />

            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/layoutUsername"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="4sp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/userId"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/airbnbcereal_w_lt"
                    android:gravity="start"
                    android:text="@string/dummy_id"
                    android:textAlignment="viewStart"
                    android:textColor="@color/white_60"
                    android:textSize="14sp" />

                <ImageView
                    android:id="@+id/copy"
                    android:layout_width="15sp"
                    android:layout_height="15sp"
                    android:layout_gravity="center"
                    android:layout_marginStart="5sp"
                    android:src="@drawable/icon_copy" />
            </androidx.appcompat.widget.LinearLayoutCompat>


            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:layout_marginBottom="@dimen/_7sdp"
                android:layout_gravity="center"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_20dp"
                    android:backgroundTint="@color/white_10"
                    android:paddingHorizontal="10sp"
                    android:paddingVertical="4sp">

                    <androidx.cardview.widget.CardView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:layout_gravity="center"
                        android:layout_marginEnd="@dimen/_3sdp"
                        android:visibility="visible"
                        app:cardCornerRadius="7.5dp">

                        <ImageView
                            android:id="@+id/svgWebView"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:adjustViewBounds="true"
                            android:scaleType="centerCrop" />
                    </androidx.cardview.widget.CardView>

                    <TextView
                        android:id="@+id/tvCountry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:textColor="@color/white"
                        android:textSize="12sp"
                        tools:text="@string/india" />

                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10sp"
                    android:background="@drawable/bg_20dp"
                    android:backgroundTint="#1AFF0000"
                    android:paddingHorizontal="10sp"
                    android:paddingVertical="4sp">

                    <ImageView
                        android:id="@+id/ivLevel"
                        android:layout_width="12sp"
                        android:layout_height="12sp"
                        android:layout_marginEnd="3dp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_level1" />

                    <TextView
                        android:id="@+id/tvLevel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="Lv. 1"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_20dp"
                    android:backgroundTint="#1AFFFF00"
                    android:paddingHorizontal="10sp"
                    android:paddingVertical="4sp">

                    <ImageView
                        android:id="@+id/ivGender"
                        android:layout_width="12sp"
                        android:layout_height="12sp"
                        android:layout_gravity="center"
                        android:src="@drawable/ic_female" />

                    <TextView
                        android:id="@+id/tvAge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="2sp"
                        android:fontFamily="@font/airbnbcereal_w_md"
                        android:text="20"
                        android:textColor="@color/white"
                        android:textSize="12sp" />
                </LinearLayout>

            </LinearLayout>

            <HorizontalScrollView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/layEditDetails"
                android:layout_gravity="center"
                android:layout_toEndOf="@id/latProfile"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:scrollbars="none"
                android:visibility="visible">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:id="@+id/tvType"
                        android:layout_width="55dp"
                        android:layout_height="20dp"
                        android:orientation="vertical"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/ic_agency_tag"
                        android:visibility="visible">

                    </LinearLayout>



                    <LinearLayout
                        android:id="@+id/tvHostType"
                        android:layout_width="55dp"
                        android:layout_height="20dp"
                        android:orientation="vertical"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/ic_host_tag"
                        android:visibility="visible">


                    </LinearLayout>


                    <LinearLayout
                        android:id="@+id/tvBdType"
                        android:layout_width="45dp"
                        android:layout_height="20dp"
                        android:orientation="vertical"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/ic_bd_tag"
                        android:visibility="gone">


                    </LinearLayout>

                    <LinearLayout
                        android:id="@+id/tvVIPType"
                        android:layout_width="45dp"
                        android:layout_height="20dp"
                        android:orientation="vertical"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/ic_vip_tag"
                        android:visibility="visible">


                    </LinearLayout>



                    <LinearLayout
                        android:id="@+id/tvCoinseller"
                        android:layout_width="60dp"
                        android:layout_height="20dp"
                        android:orientation="vertical"
                        android:layout_marginRight="5dp"
                        android:background="@drawable/ic_coinseller_tag"
                        android:visibility="visible">



                    </LinearLayout>

                </LinearLayout>

            </HorizontalScrollView>

        </LinearLayout>

        <androidx.appcompat.widget.LinearLayoutCompat
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@id/detailLay"
            android:layout_marginTop="5dp"
            android:layout_marginBottom="5dp"
            android:paddingVertical="@dimen/_10sdp">

            <LinearLayout
                android:id="@+id/unMuteMic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_weight="1"
                android:gravity="center"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/mute"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/speaker" />

                <TextView
                    android:id="@+id/txtMic"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/mute_mic"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:textColor="@color/white"
                    android:textSize="16dp" />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/removeSit"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/seat"
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_gravity="center"
                    android:src="@drawable/remove_sit" />

                <TextView
                    android:id="@+id/txtSeat"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/remove_seat"
                    android:layout_gravity="center"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:textColor="@color/white"
                    android:textSize="16dp"  />
            </LinearLayout>

            <LinearLayout
                android:id="@+id/kickOut"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <ImageView
                    android:layout_width="@dimen/_40sdp"
                    android:layout_height="@dimen/_40sdp"
                    android:layout_gravity="center"
                    android:padding="2dp"
                    android:src="@drawable/ic_kick_out" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:text="@string/kick_out"
                    android:layout_gravity="center"
                    android:fontFamily="@font/airbnbcereal_w_md"
                    android:textColor="@color/white"
                    android:textSize="16dp"  />
            </LinearLayout>
        </androidx.appcompat.widget.LinearLayoutCompat>

        </RelativeLayout>

    </FrameLayout>
</layout>