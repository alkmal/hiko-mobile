<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/_5sdp"
    android:background="@drawable/store_tab_unselected_background"
    android:gravity="center"
    android:orientation="vertical"
   >

    <TextView
        android:id="@+id/tvPaymentName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/airbnb_cereal_bold"
        android:gravity="center"
        android:textColor="@color/tabDeselected"
        android:textSize="18sp" />

    <View
        android:id="@+id/indicator"
        android:layout_width="70dp"
        android:layout_height="2dp"
        android:layout_marginTop="5dp"
        android:background="@drawable/dot_selected" />
</LinearLayout>