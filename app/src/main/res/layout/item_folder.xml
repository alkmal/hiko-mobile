<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/folder_bg"
        android:layout_marginHorizontal="10dp"
        android:paddingVertical="15dp"
        android:layout_marginTop="15dp"
        android:paddingHorizontal="10dp">

        <ImageView
            android:id="@+id/folderIcon"
            android:layout_width="35dp"
            android:layout_height="35dp"
            android:layout_gravity="center"
            android:layout_marginStart="5dp"
            android:src="@drawable/ic_blue_folder"
            />

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">


            <TextView
                android:id="@+id/folderName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Download"
                android:textSize="18sp"
                android:fontFamily="@font/airbnb_cereal_bold"
                android:textColor="@color/white"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/folderInfo"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/white_60"
                android:singleLine="true"
                android:layout_marginTop="5dp"
                android:fontFamily="@font/airbnb_cereal_light"
                android:text="33 Songs /storage/emulated/0/Folder"
                android:textSize="14sp" />
        </LinearLayout>


        <TextView
            android:id="@+id/txtselectedCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3 songs"
            android:gravity="right"
            android:textSize="14sp"
            android:layout_gravity="center"
            android:textColor="@color/pink"
            android:fontFamily="@font/airbnb_cereal_regular"/>

    </LinearLayout>
</layout>