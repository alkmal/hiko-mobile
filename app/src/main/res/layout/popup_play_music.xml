<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data></data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:elevation="5dp"
            app:cardBackgroundColor="#2F0F4B"
            app:cardCornerRadius="20dp"
            app:cardUseCompatPadding="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingVertical="20dp">

                <!-- Title Row -->
                <RelativeLayout
                    android:id="@+id/lyttop"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:id="@+id/tvTitle"
                        android:layout_width="150dp"
                        android:layout_height="wrap_content"
                        android:layout_centerVertical="true"
                        android:fontFamily="@font/airbnb_cereal_bold"
                        android:singleLine="true"
                        android:text="AUDIO"
                        android:textColor="@color/white"
                        android:textSize="16sp" />

                    <ImageView
                        android:id="@+id/ivAdd"
                        android:layout_width="30dp"
                        android:layout_height="30dp"
                        android:layout_marginEnd="10dp"
                        android:layout_toStartOf="@id/ivClose"
                        android:src="@drawable/ic_music_add" />

                    <ImageView
                        android:id="@+id/ivClose"
                        android:layout_width="25dp"
                        android:layout_height="25dp"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:src="@drawable/ic_music_close" />

                </RelativeLayout>

                <!-- Time Labels -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="20dp"
                    android:layout_marginTop="3dp">

                    <TextView
                        android:id="@+id/txtstarttime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnb_cereal_regular"
                        android:text="00:00"
                        android:textColor="@color/white" />

                    <TextView
                        android:id="@+id/txttotaltime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:fontFamily="@font/airbnb_cereal_regular"
                        android:text="00:00"
                        android:textColor="@color/white" />

                </RelativeLayout>

                <!-- ✅ Music SeekBar — margin parent પર, seekbar પર નહીં -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5dp"
                    android:layout_marginHorizontal="20dp">

                    <SeekBar
                        android:id="@+id/seekbar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="20dp"
                        android:background="@null"
                        android:maxHeight="20dp"
                        android:minHeight="20dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:thumbOffset="10dp"
                        android:max="100"
                        android:progress="50"
                        android:progressDrawable="@drawable/seekbar_progress"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_musicthumb" />

                </RelativeLayout>

                <!-- Play Controls -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10dp"
                    android:layout_marginTop="20dp"
                    android:layout_marginBottom="20dp">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_centerHorizontal="true"
                        android:gravity="center">

                        <ImageView
                            android:id="@+id/ivPrevious"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:src="@drawable/ic_music_previous" />

                        <ImageView
                            android:id="@+id/ivplay"
                            android:layout_width="45dp"
                            android:layout_height="45dp"
                            android:layout_marginHorizontal="50dp"
                            android:src="@drawable/ic_music_play" />

                        <ImageView
                            android:id="@+id/ivNext"
                            android:layout_width="25dp"
                            android:layout_height="25dp"
                            android:src="@drawable/ic_music_next" />

                    </LinearLayout>

                </RelativeLayout>

                <!-- ✅ Volume SeekBar — same style as music seekbar -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="40dp"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <ImageView
                        android:id="@+id/ivSound"
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:padding="3dp"
                        android:src="@drawable/ic_low_sound" />

                    <SeekBar
                        android:id="@+id/soundSeekbar"
                        style="@android:style/Widget.ProgressBar.Horizontal"
                        android:layout_width="0dp"
                        android:layout_height="25dp"
                        android:layout_marginHorizontal="7dp"
                        android:layout_weight="1"
                        android:background="@null"
                        android:maxHeight="20dp"
                        android:minHeight="20dp"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp"
                        android:thumbOffset="10dp"
                        android:max="100"
                        android:progress="60"
                        android:progressDrawable="@drawable/seekbar_soundprogress"
                        android:splitTrack="false"
                        android:thumb="@drawable/seekbar_progressthumb"
                        />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:padding="3dp"
                        android:src="@drawable/ic_high_sound" />

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>
</layout>