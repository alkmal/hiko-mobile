<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center"
                android:orientation="vertical"
                android:background="@drawable/popup_bg"
                android:paddingVertical="@dimen/_10sdp">

                <ImageView
                    android:id="@+id/ivVector"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_privacy_policy" />

                <TextView
                    android:id="@+id/tvName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginTop="5dp"
                    android:fontFamily="@font/airbnbcereal_w_xbd"
                    android:text="@string/privacy_policy"
                    android:textColor="@color/white"
                    android:textSize="20sp" />


                <TextView
                    android:id="@+id/textview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="5sp"
                    android:layout_marginHorizontal="10dp"
                    android:fontFamily="@font/airbnbcereal_w_bk"
                    android:gravity="center"
                    android:text="@string/if_you_go_back_now_you_will_lose_all_the_clips_added_to_your_video"
                    android:textColor="@color/white_80"
                    android:textSize="12sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="5dp"
                    android:layout_marginHorizontal="@dimen/_5sdp"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatCheckBox
                        android:id="@+id/checkbox"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:buttonTint="@color/white"
                        android:drawableTint="@color/white" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="@font/airbnbcereal_w_lt"
                        android:text="@string/accept_privacy_policy"
                        android:textColor="@color/textColor"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="7sp"
                    android:layout_marginBottom="2sp"
                    android:layout_marginTop="15sp"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tvCancel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:layout_marginHorizontal="5sp"
                        android:fontFamily="@font/airbnbcereal_w_bd"
                        android:background="@drawable/gray_strock_30"
                        android:text="@string/deny"
                        android:textSize="18sp"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="10dp"
                        android:textColor="@color/hintColor" />

                    <TextView
                        android:id="@+id/tvContinue"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:background="@drawable/gradient_bg_radius_50"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:paddingHorizontal="10sp"
                        android:paddingVertical="10dp"
                        android:textSize="18sp"
                        android:layout_marginHorizontal="5sp"
                        android:text="@string/accept"
                        android:fontFamily="@font/airbnbcereal_w_bd"
                        android:textColor="@color/white" />



                </LinearLayout>

            </LinearLayout>


        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/pd"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_centerInParent="true"
            android:visibility="gone"
            app:lottie_autoPlay="true"
            app:lottie_loop="true"
            app:lottie_rawRes="@raw/all_in_one_loader"
            app:lottie_speed="2.5" />
    </RelativeLayout>
</layout>