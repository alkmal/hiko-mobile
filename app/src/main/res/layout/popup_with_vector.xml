<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="240dp"
                android:background="@drawable/popup_bg"
                android:gravity="center"
                android:layout_margin="10dp"
                android:orientation="vertical">

                <ImageView
                    android:id="@+id/ivVector"
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:layout_marginTop="2dp"
                    android:src="@drawable/ic_successfull" />

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="15dp"
                    android:layout_marginHorizontal="10dp"
                    android:fontFamily="@font/airbnbcereal_w_xbd"
                    android:gravity="center"
                    android:text="@string/all_seats_are_taken"
                    android:textColor="@color/white"
                    android:textSize="20sp" />

                <TextView
                    android:id="@+id/tvText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/_5sdp"
                    android:layout_marginHorizontal="10dp"
                    android:fontFamily="@font/airbnbcereal_w_bk"
                    android:gravity="center"
                    android:text="@string/please_wait_for_a_spot_to_open"
                    android:textColor="@color/white_80"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/btnContinue"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="15dp"
                    android:layout_marginBottom="5dp"
                    android:layout_marginTop="@dimen/_15sdp"
                    android:background="@drawable/gradient_bg_radius_50"
                    android:fontFamily="@font/airbnbcereal_w_bd"
                    android:gravity="center"
                    android:paddingVertical="@dimen/_10sdp"
                    android:text="@string/okay"
                    android:textColor="@color/white"
                    android:textSize="18sp" />
            </LinearLayout>

    </LinearLayout>
</layout>