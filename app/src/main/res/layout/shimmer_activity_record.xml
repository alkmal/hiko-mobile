<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools">

    <data>

    </data>

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true"
        tools:context=".profile.activity.RecordActivity">

        <RelativeLayout
            android:id="@+id/topLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10sp"
            android:gravity="center_vertical"
            android:layoutDirection="locale">

            <ImageView
                android:id="@+id/ivBack"
                style="@style/toolBarBackImageStyle"
                android:background="@color/shimmerColor"
                android:onClick="onClickBack"
                app:tint="@color/shimmerColor" />

            <androidx.appcompat.widget.AppCompatTextView
                style="@style/toolBarTextStyle"
                android:layout_centerVertical="true"
                android:background="@color/shimmerColor"
                android:textColor="@color/shimmerColor"
                android:text="@string/history" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@id/topLayout"
            android:layout_marginHorizontal="15sp"
            android:orientation="vertical">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="@dimen/_10sdp"
                android:paddingVertical="5sp"
                android:background="@color/shimmerColor"
                android:orientation="vertical">



            </androidx.appcompat.widget.LinearLayoutCompat>

            <LinearLayout
                android:id="@+id/lytDiamonds"
                android:layout_width="match_parent"
                android:layout_height="186sp"
                android:layout_marginTop="@dimen/_15sdp"
                android:background="@drawable/bg_diamond_record"
                android:backgroundTint="@color/shimmerColor"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10sp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">
                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:paddingHorizontal="10sp"
                        android:paddingVertical="10sp"
                        android:background="@drawable/bg_radius13_whitestrock12"
                        android:backgroundTint="@color/shimmerColor">


                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp"
                    android:layout_weight="1.5"
                    android:gravity="center"
                    android:background="@drawable/bg_radius19_whitestrock12"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDimondsIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1452"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/income"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="52sp"
                        android:background="@color/white_10" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvDiamondsOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:background="@color/shimmerColor"
                            android:text="1253"
                            android:textColor="@color/shimmerColor"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/outcome"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/lytRcoins"
                android:layout_width="match_parent"
                android:layout_height="186sp"
                android:layout_marginTop="@dimen/_15sdp"
                android:background="@drawable/bg_rcoin_record"
                android:backgroundTint="@color/shimmerColor"
                android:orientation="vertical">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="10sp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:orientation="horizontal">


                    <LinearLayout
                        android:layout_width="50dp"
                        android:layout_height="50dp"
                        android:layout_gravity="center"
                        android:paddingHorizontal="10sp"
                        android:paddingVertical="10sp"
                        android:background="@drawable/bg_radius13_whitestrock12">


                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_marginHorizontal="@dimen/_10sdp"
                    android:layout_marginVertical="@dimen/_10sdp"
                    android:layout_weight="1.5"
                    android:gravity="center"
                    android:background="@drawable/bg_radius19_whitestrock12"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/lytFollowing"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRcoinIncome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:text="1452"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="22sp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/income"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="14sp" />
                    </LinearLayout>

                    <View
                        android:layout_width="1dp"
                        android:layout_height="52sp"
                        android:background="@color/white_10" />

                    <LinearLayout
                        android:id="@+id/lytFollowers"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:gravity="center"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/tvRcoinOutcome"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="@font/airbnbcereal_w_bd"
                            android:paddingHorizontal="@dimen/_5sdp"
                            android:singleLine="true"
                            android:background="@color/shimmerColor"
                            android:text="1452"
                            android:textColor="@color/shimmerColor"
                            android:textSize="22sp" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="5dp"
                            android:fontFamily="@font/airbnbcereal_w_md"
                            android:text="@string/outcome"
                            android:background="@color/shimmerColor"
                            android:textColor="@color/shimmerColor"
                            android:textSize="14sp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

    </RelativeLayout>
</layout>