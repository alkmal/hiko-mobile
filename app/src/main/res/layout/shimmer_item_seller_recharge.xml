<?xml version="1.0" encoding="utf-8"?>
<layout xmlns:android="http://schemas.android.com/apk/res/android">

    <data>

    </data>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="@dimen/_10sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:background="@drawable/radious_15_grey"
        android:backgroundTint="@color/white_10"
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingHorizontal="@dimen/_10sdp"
        android:paddingVertical="@dimen/_10sdp">

        <ImageView
            android:layout_width="@dimen/_30sdp"
            android:layout_height="@dimen/_30sdp"
            android:layout_gravity="center"
            android:layout_marginEnd="10dp"
            android:background="@drawable/profile_round_bg"
            android:backgroundTint="@color/shimmerColor"
            android:padding="@dimen/_1sdp"
            android:src="@drawable/profile_placeholder"
            android:tint="@color/shimmerColor" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_10dp_purewhite"
                    android:backgroundTint="@color/shimmerColor"
                    android:fontFamily="@font/airbnb_cereal_medium"
                    android:text="@string/gift_received"
                    android:textColor="@color/shimmerColor" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/airbnb_cereal_bold"
                android:text="@string/dummy_name"
                android:textColor="@color/frostBlue"
                android:visibility="gone" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:background="@drawable/bg_10dp_purewhite"
                android:backgroundTint="@color/shimmerColor"
                android:fontFamily="@font/alight"
                android:text="23/12/1019   04:55 PM"
                android:textColor="@color/shimmerColor"
                android:textSize="12sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/btn_bg"
            android:backgroundTint="@color/shimmerColor"
            android:paddingHorizontal="@dimen/_10sdp"
            android:paddingVertical="@dimen/_3sdp"
            android:text="-1001"
            android:textColor="@color/shimmerColor" />
    </LinearLayout>
</layout>