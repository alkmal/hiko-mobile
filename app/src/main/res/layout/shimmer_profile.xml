                                android:layout_height="wrap_content"
                                android:layout_marginHorizontal="15dp"
                                android:orientation="vertical">

                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_70sdp"
                                    android:layout_marginTop="@dimen/_10sdp"
                                    android:background="@drawable/card_bg"
                                    android:backgroundTint="#B3FFFFFF"
                                    android:weightSum="3">

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="1021"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_16sdp" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="@string/following"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_10sdp" />
                                    </LinearLayout>

                                    <View
                                        android:layout_width=".3dp"
                                        android:layout_height="match_parent"
                                        android:layout_marginVertical="@dimen/_10sdp"
                                        android:background="@color/hintColor" />

                                    <LinearLayout
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="1021"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_16sdp" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="@string/followers"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_10sdp" />
                                    </LinearLayout>

                                    <View
                                        android:layout_width=".3dp"
                                        android:layout_height="match_parent"
                                        android:layout_marginVertical="@dimen/_10sdp"
                                        android:background="@color/hintColor" />

                                    <LinearLayout
                                        android:id="@+id/lytBlock"
                                        android:layout_width="wrap_content"
                                        android:layout_height="match_parent"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:layout_weight="1"
                                        android:gravity="center"
                                        android:orientation="vertical"
                                        android:padding="@dimen/_5sdp">

                                        <TextView
                                            android:id="@+id/tvBlock"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="1021"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_16sdp" />

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="@string/block"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_10sdp" />
                                    </LinearLayout>
                                </androidx.appcompat.widget.LinearLayoutCompat>

                                <LinearLayout
                                    android:id="@+id/layWallet"
                                    android:layout_width="match_parent"
                                    android:layout_height="@dimen/_75sdp"
                                    android:layout_marginTop="@dimen/_15sdp"
                                    android:background="@drawable/gradient_bg"
                                    android:backgroundTint="@color/shimmerColor2"
                                    android:gravity="center"
                                    android:padding="@dimen/_10sdp">

                                    <ImageView
                                        android:layout_width="@dimen/_50sdp"
                                        android:layout_height="wrap_content"
                                        android:src="@drawable/diamond"
                                        android:tint="@color/shimmerColor" />

                                    <LinearLayout
                                        android:layout_width="0dp"
                                        android:layout_height="match_parent"
                                        android:layout_marginStart="@dimen/_10sdp"
                                        android:layout_weight="1"
                                        android:gravity="center_vertical"
                                        android:orientation="vertical">

                                        <TextView
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:background="@drawable/bg_10dp_purewhite"
                                            android:backgroundTint="@color/shimmerColor"
                                            android:fontFamily="@font/airbnb_cereal_medium"
                                            android:text="@string/my_diamonds"
                                            android:textColor="@color/shimmerColor"
                                            android:textSize="@dimen/_10sdp" />

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginTop="@dimen/_5sdp">

                                            <TextView
                                                android:id="@+id/tvCoin"
                                                android:layout_width="wrap_content"
                                                android:layout_height="wrap_content"
                                                android:layout_gravity="center"
                                                android:background="@drawable/bg_10dp_purewhite"
                                                android:backgroundTint="@color/shimmerColor"
                                                android:ellipsize="end"
                                                android:fontFamily="@font/airbnb_cereal_bold"
                                                android:singleLine="true"
                                                android:text="2408"
                                                android:textColor="@color/shimmerColor"
                                                android:textSize="@dimen/_18sdp" />
                                        </LinearLayout>
                                    </LinearLayout>

                                    <androidx.appcompat.widget.AppCompatTextView
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_10dp_purewhite"
                                        android:backgroundTint="@color/shimmerColor"
                                        android:drawableTint="@color/shimmerColor"
                                        android:fontFamily="@font/airbnb_cereal_bold"
                                        android:paddingHorizontal="@dimen/_10sdp"
                                        android:paddingVertical="@dimen/_7sdp"
                                        android:text="@string/my_wallet"
                                        android:textColor="@color/shimmerColor"
                                        android:textSize="@dimen/_10sdp"
                                        app:drawableEndCompat="@drawable/icon_double_arrow"
                                        tools:ignore="HardcodedText" />
                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/hostVipSection"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_15sdp"
                                    android:background="@drawable/card_bg"
                                    android:padding="15dp"
                                    android:orientation="vertical"
                                   >

                                    <TextView
                                        android:id="@+id/tvHostVipTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_10dp_purewhite"
                                        android:backgroundTint="@color/shimmerColor"
                                        android:text="dfbdfgbsdtnbsfgnfgnb"
                                        android:textColor="@color/shimmerColor"
                                        android:textSize="16sp" />

                                    <androidx.appcompat.widget.LinearLayoutCompat
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_marginTop="@dimen/_15sdp"
                                        android:layout_marginBottom="@dimen/_5sdp">

                                        <include
                                            layout="@layout/shimmer_item_rvprofile"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1" />

                                        <include
                                            layout="@layout/shimmer_item_rvprofile"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1" />

                                        <include
                                            layout="@layout/shimmer_item_rvprofile"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1" />

                                        <include
                                            layout="@layout/shimmer_item_rvprofile"
                                            android:layout_width="wrap_content"
                                            android:layout_height="wrap_content"
                                            android:layout_weight="1" />
                                    </androidx.appcompat.widget.LinearLayoutCompat>
                                </LinearLayout>

                                <LinearLayout
                                    android:id="@+id/myFeaturesSection"
                                    android:layout_width="match_parent"
                                    android:layout_height="wrap_content"
                                    android:layout_marginTop="@dimen/_10sdp"
                                    android:background="@drawable/card_bg"
                                    android:orientation="vertical"
                                    android:padding="15dp">

                                    <TextView
                                        android:id="@+id/tvMyFeaturesTitle"
                                        android:layout_width="wrap_content"
                                        android:layout_height="wrap_content"
                                        android:background="@drawable/bg_10dp_purewhite"
                                        android:backgroundTint="@color/shimmerColor"
                                        android:text="dfbsdgbdfgnfgnbZ"
                                        android:textColor="@color/shimmerColor"
                                        android:textSize="16sp"
                                        android:textStyle="bold" />

                                    <androidx.appcompat.widget.LinearLayoutCompat
                                        android:layout_width="match_parent"
                                        android:layout_height="match_parent"
                                        android:layout_marginTop="@dimen/_15sdp"
                                        android:layout_marginBottom="@dimen/_5sdp"
                                        android:orientation="vertical">

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginVertical="@dimen/_5sdp"
                                            android:gravity="center">

                                            <RelativeLayout
                                                android:id="@+id/layAgency"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:id="@+id/ivAgency"
                                                    android:layout_width="50sp"
                                                    android:layout_height="50sp"
                                                    android:layout_gravity="center"
                                                    android:src="@drawable/ic_agency_center"
                                                    app:tint="@color/shimmerColor" />

                                                <TextView
                                                    android:id="@+id/tvAgency"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:maxLines="2"
                                                    android:layout_toEndOf="@id/ivAgency"
                                                    android:layout_marginStart="10sp"
                                                    android:background="@color/shimmerColor"
                                                    android:fontFamily="@font/airbnbcereal_w_bd"
                                                    android:layout_centerVertical="true"
                                                    android:text="@string/demo_agency_center"
                                                    android:textColor="@color/shimmerColor"
                                                    android:textSize="16sp" />

                                                <ImageView
                                                    android:layout_width="24sp"
                                                    android:layout_height="24sp"
                                                    android:layout_centerVertical="true"
                                                    android:layout_alignParentEnd="true"
                                                    android:background="@color/shimmerColor"
                                                    android:src="@drawable/icon_redirect"
                                                    app:tint="@color/shimmerColor" />
                                            </RelativeLayout>
                                        </LinearLayout>

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginVertical="@dimen/_5sdp"
                                            android:gravity="center">

                                            <RelativeLayout
                                                android:id="@+id/layAgency1"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:id="@+id/ivAgency1"
                                                    android:layout_width="50sp"
                                                    android:layout_height="50sp"
                                                    android:layout_gravity="center"
                                                    android:src="@drawable/ic_agency_center"
                                                    app:tint="@color/shimmerColor" />

                                                <TextView
                                                    android:id="@+id/tvAgency1"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:maxLines="2"
                                                    android:layout_toEndOf="@id/ivAgency1"
                                                    android:layout_marginStart="10sp"
                                                    android:background="@color/shimmerColor"
                                                    android:fontFamily="@font/airbnbcereal_w_bd"
                                                    android:layout_centerVertical="true"
                                                    android:text="@string/demo_agency_center"
                                                    android:textColor="@color/shimmerColor"
                                                    android:textSize="16sp" />

                                                <ImageView
                                                    android:layout_width="24sp"
                                                    android:layout_height="24sp"
                                                    android:layout_centerVertical="true"
                                                    android:layout_alignParentEnd="true"
                                                    android:background="@color/shimmerColor"
                                                    android:src="@drawable/icon_redirect"
                                                    app:tint="@color/shimmerColor" />
                                            </RelativeLayout>
                                        </LinearLayout>

                                        <LinearLayout
                                            android:layout_width="match_parent"
                                            android:layout_height="wrap_content"
                                            android:layout_marginVertical="@dimen/_5sdp"
                                            android:gravity="center">

                                            <RelativeLayout
                                                android:id="@+id/layAgency2"
                                                android:layout_width="match_parent"
                                                android:layout_height="wrap_content"
                                                android:orientation="horizontal">

                                                <ImageView
                                                    android:id="@+id/ivAgency2"
                                                    android:layout_width="50sp"
                                                    android:layout_height="50sp"
                                                    android:layout_gravity="center"
                                                    android:src="@drawable/ic_agency_center"
                                                    app:tint="@color/shimmerColor" />

                                                <TextView
                                                    android:id="@+id/tvAgency2"
                                                    android:layout_width="wrap_content"
                                                    android:layout_height="wrap_content"
                                                    android:maxLines="2"
                                                    android:layout_toEndOf="@id/ivAgency2"
                                                    android:layout_marginStart="10sp"
                                                    android:background="@color/shimmerColor"
                                                    android:fontFamily="@font/airbnbcereal_w_bd"
                                                    android:layout_centerVertical="true"
                                                    android:text="@string/demo_agency_center"
                                                    android:textColor="@color/shimmerColor"
                                                    android:textSize="16sp" />

                                                <ImageView
                                                    android:layout_width="24sp"
                                                    android:layout_height="24sp"
                                                    android:layout_centerVertical="true"
                                                    android:layout_alignParentEnd="true"
                                                    android:background="@color/shimmerColor"
                                                    android:src="@drawable/icon_redirect"
                                                    app:tint="@color/shimmerColor" />
                                            </RelativeLayout>
